{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpengine-smart-search/active-filters-facet",
  "version": "0.1.0",
  "title": "Active Filters Facet",
  "category": "wpengine-smart-search",
  "icon": "visibility",
  "description": "WP Engine Smart Search block for showing active filters.",
  "example": {},
  "supports": {
    "html": false,
    "interactivity": true,
    "align": ["wide", "full"],
    "anchor": true,
    "className": true
  },
  "attributes": {
    "hasLabel": {
      "type": "boolean",
      "default": true
    },
    "label": {
      "type": "string",
      "default": "Active Filters Label"
    },
    "selectedDataSources": {
      "type": "object",
      "default": {}
    }
  },
  "keywords": [
    "wpengine",
    "WP Engine",
    "smart search",
    "smartsearch",
    "Smart Search",
    "active filters",
    "active",
    "categories"
  ],
  "textdomain": "wpengine-smart-search",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewStyle": "file:./style-index.css",
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
