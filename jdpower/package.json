{
	"name": "jdpower",
	"version": "1.0.0",
	"author": "Decision Counsel",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"devDependencies": {
		"@wordpress/scripts": "^12.1.0",
		"dir-archiver": "^1.1.1",
		"node-sass-package-importer": "^5.3.2",
		"rtlcss": "^2.5.0",
		"sass": "1.32.13"
	},
	"rtlcssConfig": {
		"options": {
			"autoRename": false,
			"autoRenameStrict": false,
			"blacklist": {},
			"clean": true,
			"greedy": false,
			"processUrls": false,
			"stringMap": []
		},
		"plugins": [],
		"map": false
	},
	"scripts": {
		"compile:css": "sass sass/style.scss style.css --style=compressed",
		"lint:scss": "wp-scripts lint-style 'sass/**/*.scss'",
		"lint:js": "wp-scripts lint-js 'js/*.js'",
		"bundle": "node bin/bundle.js",
		"dev": "sass --watch sass/style.scss:style.css"
	}
}
